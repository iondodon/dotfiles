# You can preview the config here

# this is for ghostty v1.3.1

gtk-custom-css = ~/.config/ghostty/custom-style.css

background = #111216 
background-opacity = 0.8
background-blur = 20
selection-background = #d79921
selection-foreground = #111216

window-decoration = none
window-theme = dark
window-padding-x = 2
window-padding-y = 0
window-padding-balance = true
window-padding-color = extend-always
window-save-state = always

gtk-titlebar = false
gtk-wide-tabs = true

cursor-style = block
cursor-style-blink = true

shell-integration-features = no-cursor

font-feature = -calt
font-feature = -liga
font-feature = -dlig
